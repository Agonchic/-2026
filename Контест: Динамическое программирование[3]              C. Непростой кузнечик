#include <iostream>
#include <vector>
 
using namespace std;
 
int main() {
    int l, r;
    cin >> l >> r;
 
    const int c = 1000000007;
 
    vector<int> av(r + 1, 0);
    av[1] = 1;
 
    for (int i = 1; i <= r; ++i) {
        if (av[i] == 0) {
            continue;
        }
 
        for (int j = 2 * i; j <= r; j += i) {
            av[j] = (av[j] + av[i]) % c;
        }
    }
 
    long long ans = 0;
    for (int i = l; i <= r; ++i) {
        ans = (ans + av[i]) % c;
    }
 
    cout << ans << "\n";
 
    return 0;
}
