#include <iostream>
using namespace std;
 
int main() {
    int n;
    cin >> n;
    int a[n];
    for(int i = 0; i < n; i++){
        cin >> a[i];
    }
    int l, r;
    while (cin >> l >> r && (l != 0 && r != 0)){
        while(l < r){
            int la = a[l - 1];
        a[l - 1] = a[r - 1];
        a[r - 1] = la;
        l++;
        r--;
        }
        
    }
    for(int i = 0; i < n; i++){
        cout << a[i] << " ";
    }
    return 0;
}
