#include <iostream>
#include <vector>
 
using namespace std;
 
int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
 
    int n;
    cin >> n;
 
    vector<long long> t(n);
    for (int i = 0; i < n; ++i) {
        cin >> t[i];
    }
 
    long long NOD = t[0];
 
    for (int i = 1; i < n; ++i) {
        long long a = NOD;
        long long b = t[i];
        while (b > 0) {
            a %= b;
            long long tmp = a;
            a = b;
            b = tmp;
        }
        long long gcd = a;
        NOD = (NOD / gcd) * t[i];
    }
 
    cout << NOD << "\n";
    return 0;
}
